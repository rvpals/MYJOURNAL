<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/login_bg">

    <!-- Top Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/login_card_bg"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_open_search"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="🔍"
            android:textSize="16sp"
            android:background="@drawable/btn_search_3d"
            android:layout_marginEnd="8dp"
            android:elevation="4dp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/nav_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Journal"
            android:textColor="@color/login_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <Button
            android:id="@+id/btn_new_entry"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="✏️"
            android:textSize="16sp"
            android:background="@drawable/btn_accent"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_lock"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="🔒"
            android:textSize="16sp"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_menu"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="☰"
            android:textSize="18sp"
            android:background="@drawable/btn_secondary" />
    </LinearLayout>

    <!-- Main Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Weather + Streak Row -->
            <LinearLayout
                android:id="@+id/weather_streak_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/weather_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/login_text"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/streak_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/login_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stats Grid (2x2) -->
            <LinearLayout
                android:id="@+id/stats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  android:layout_marginBottom="6dp">

                  <LinearLayout
                      android:id="@+id/stat_total"
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:orientation="vertical"
                      android:gravity="center"
                      android:background="@drawable/stat_card_bg"
                      android:padding="16dp"
                      android:layout_marginEnd="5dp"
                      android:clickable="true"
                      android:focusable="true">

                      <TextView
                          android:id="@+id/stat_total_value"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:text="0"
                          android:textColor="@color/login_accent"
                          android:textSize="30sp"
                          android:textStyle="bold" />
                      <TextView
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:text="Total"
                          android:textColor="@color/login_text_secondary"
                          android:textSize="11sp"
                          android:textAllCaps="true"
                          android:letterSpacing="0.05" />
                  </LinearLayout>

                  <LinearLayout
                      android:id="@+id/stat_week"
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:orientation="vertical"
                      android:gravity="center"
                      android:background="@drawable/stat_card_bg"
                      android:padding="16dp"
                      android:layout_marginStart="5dp"
                      android:clickable="true"
                      android:focusable="true">

                      <TextView
                          android:id="@+id/stat_week_value"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:text="0"
                          android:textColor="@color/login_accent"
                          android:textSize="30sp"
                          android:textStyle="bold" />
                      <TextView
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:text="This Week"
                          android:textColor="@color/login_text_secondary"
                          android:textSize="11sp"
                          android:textAllCaps="true"
                          android:letterSpacing="0.05" />
                  </LinearLayout>
              </LinearLayout>

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/stat_month"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_card_bg"
                    android:padding="16dp"
                    android:layout_marginEnd="5dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/stat_month_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/login_accent"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This Month"
                        android:textColor="@color/login_text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_year"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_card_bg"
                    android:padding="16dp"
                    android:layout_marginStart="5dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/stat_year_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/login_accent"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This Year"
                        android:textColor="@color/login_text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />
                </LinearLayout>
              </LinearLayout>
            </LinearLayout>

            <!-- Quick Actions (Pinned Views) -->
            <LinearLayout
                android:id="@+id/quick_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Widgets Panel -->
            <LinearLayout
                android:id="@+id/panel_widgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Widgets"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/widgets_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Pinned Entries Panel -->
            <LinearLayout
                android:id="@+id/panel_pinned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/login_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌 Pinned"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/pinned_entries_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Recent Entries Panel -->
            <LinearLayout
                android:id="@+id/panel_recent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/login_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Entries"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/recent_entries_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Today in History Panel -->
            <LinearLayout
                android:id="@+id/panel_today_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/login_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Today in History"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/today_history_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Top Tags Panel -->
            <LinearLayout
                android:id="@+id/panel_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/login_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏷️ Top Tags"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/tags_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Top Categories Panel -->
            <LinearLayout
                android:id="@+id/panel_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/login_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📁 Top Categories"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/categories_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Top Places Panel -->
            <LinearLayout
                android:id="@+id/panel_places"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/login_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Top Places"
                    android:textColor="@color/login_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/places_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>


</LinearLayout>
