<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/login_bg">

    <!-- Top Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/login_card_bg"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="←"
            android:textSize="18sp"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/el_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Entries"
            android:textColor="@color/login_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <Button
            android:id="@+id/btn_new_entry"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="✏️"
            android:textSize="16sp"
            android:background="@drawable/btn_accent" />
    </LinearLayout>

    <!-- Filter Info collapsible header -->
    <LinearLayout
        android:id="@+id/el_filter_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@color/login_card_bg">

        <TextView
            android:id="@+id/el_filter_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶ Filter Info"
            android:textColor="@color/login_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingVertical="2dp" />

        <TextView
            android:id="@+id/el_entry_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/login_text_secondary"
            android:textSize="12sp"
            android:gravity="end"
            android:paddingEnd="4dp" />
    </LinearLayout>

    <!-- Filter Info collapsible body -->
    <LinearLayout
        android:id="@+id/el_filter_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="6dp"
            android:paddingBottom="4dp">

            <EditText
                android:id="@+id/el_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Search entries..."
                android:textColor="@color/login_text"
                android:textColorHint="@color/login_text_secondary"
                android:textSize="14sp"
                android:background="@drawable/search_bg"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_search"
                android:layout_width="42dp"
                android:layout_height="40dp"
                android:text="🔍"
                android:textSize="16sp"
                android:background="@drawable/btn_accent" />
        </LinearLayout>

        <!-- Filter Row -->
        <LinearLayout
            android:id="@+id/el_filter_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <Spinner
                android:id="@+id/el_filter_category"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_bg"
                android:layout_marginEnd="4dp" />

            <Spinner
                android:id="@+id/el_filter_tag"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_bg"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_clear_filters"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="@color/login_text_secondary"
                android:background="@drawable/btn_secondary" />
        </LinearLayout>

        <!-- Order By Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order by:"
                android:textColor="@color/login_text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

            <Spinner
                android:id="@+id/el_order_field"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_bg"
                android:layout_marginEnd="4dp" />

            <Spinner
                android:id="@+id/el_order_dir"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:background="@drawable/spinner_bg" />
        </LinearLayout>

        <!-- Toolbar Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="2dp">

            <Button
                android:id="@+id/btn_select_mode"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Select"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/login_text"
                android:background="@drawable/btn_secondary"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="6dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Spinner
                android:id="@+id/el_page_size"
                android:layout_width="70dp"
                android:layout_height="34dp"
                android:background="@drawable/spinner_bg" />
        </LinearLayout>
    </LinearLayout>

    <!-- Batch Actions (hidden by default) -->
    <LinearLayout
        android:id="@+id/el_batch_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/el_select_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 selected"
            android:textColor="@color/login_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_select_all"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="All"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/login_text"
            android:background="@drawable/btn_secondary"
            android:paddingHorizontal="10dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_deselect_all"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="None"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/login_text"
            android:background="@drawable/btn_secondary"
            android:paddingHorizontal="10dp"
            android:layout_marginEnd="4dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_delete_selected"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Delete"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/login_text"
            android:background="@drawable/btn_delete"
            android:paddingHorizontal="10dp" />
    </LinearLayout>

    <!-- Entry List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/el_entries_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp" />
    </ScrollView>

    <!-- Pagination -->
    <LinearLayout
        android:id="@+id/el_pagination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp"
        android:background="@color/login_card_bg"
        android:elevation="4dp" />

</LinearLayout>
