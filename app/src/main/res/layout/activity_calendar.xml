<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/login_bg">

    <!-- Top Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/login_card_bg"
        android:elevation="4dp">

        <Button
            android:id="@+id/cal_btn_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="←"
            android:textSize="18sp"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/cal_nav_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Calendar"
            android:textColor="@color/login_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <Button
            android:id="@+id/cal_btn_today"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Today"
            android:textSize="12sp"
            android:textColor="@color/login_text"
            android:background="@drawable/btn_secondary"
            android:paddingHorizontal="12dp"
            android:textAllCaps="false" />
    </LinearLayout>

    <!-- Month Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <Button
            android:id="@+id/cal_btn_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="◀"
            android:textSize="14sp"
            android:background="@drawable/btn_secondary" />

        <TextView
            android:id="@+id/cal_month_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="April 2026"
            android:textColor="@color/login_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/cal_btn_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="▶"
            android:textSize="14sp"
            android:background="@drawable/btn_secondary" />
    </LinearLayout>

    <!-- Weekday Header -->
    <LinearLayout
        android:id="@+id/cal_weekday_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingBottom="4dp" />

    <!-- Calendar Grid -->
    <LinearLayout
        android:id="@+id/cal_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="6dp" />

    <!-- Selected Day Results -->
    <LinearLayout
        android:id="@+id/cal_results_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/login_card_bg"
        android:padding="14dp"
        android:layout_margin="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/cal_results_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/login_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/cal_results_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <!-- Spacer when no results -->
    <View
        android:id="@+id/cal_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
